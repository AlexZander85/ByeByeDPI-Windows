# Patch: adaptive/seq_spoof.rs
#
# Обновляет вызов build_client_hello для передачи PerConnRng.
# Если conntrack entry имеет rng, используем его; иначе fallback на default.
#
# Применить: cd src/core/src/adaptive && patch seq_spoof.rs < seq_spoof.rs.patch

--- a/src/core/src/adaptive/seq_spoof.rs
+++ b/src/core/src/adaptive/seq_spoof.rs
@@ -79,11 +79,16 @@
     hop_tab: &HopTab,
 ) -> Result<SeqSpoofResult> {
-    let fake_ch = ch_gen::build_client_hello(fake_sni);
+    // Используем per-conn RNG из conntrack, если доступен
+    let fake_ch = if let Some(entry) = _conntrack.get(&ConnKey::new(src_ip, dst_ip, src_port, dst_port)) {
+        let mut rng = entry.rng.clone().unwrap_or_else(|| crate::desync::rand::PerConnRng::new(0));
+        ch_gen::build_client_hello(fake_sni, &mut rng)
+    } else {
+        ch_gen::build_client_hello_default(fake_sni)
+    };

     // Определяем fake TTL из HopTab
     let fake_ttl = hop_tab
         .fake_ttl_for_ip(&dst_ip)
         .unwrap_or(64); // fallback, если нет данных

@@ -263,7 +268,12 @@
     dst_port: u16,
     client_isn: u32,
 ) -> Result<SeqSpoofResult> {
-    let fake_ch = ch_gen::build_client_hello(fake_sni);
+    // badsum variant — нет conntrack, используем default RNG
+    let fake_ch = ch_gen::build_client_hello_default(fake_sni);

     let mut packet = build_fake_tcp_packet(
         src_ip,
