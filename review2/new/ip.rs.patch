# Patch: desync/ip.rs
#
# Заменяет локальную build_fake_ch на вызов ch_gen::build_client_hello_default.
# Это убирает дублирование кода и применяет все Sprint 1 техники (GREASE, PQ, padding)
# к fake CH, используемому в frag_overlap.
#
# Применить: cd src/core/src/desync && patch ip.rs < ip.rs.patch

--- a/src/core/src/desync/ip.rs
+++ b/src/core/src/desync/ip.rs
@@ -1,5 +1,7 @@
 //! IP-level Desync техники.

+use crate::adaptive::ch_gen;
+
 use crate::desync::{parse_ip_header, DesyncResult, ipv4_checksum};
 use pnet_packet::ip::IpNextHeaderProtocol;
 use pnet_packet::ipv4::MutableIpv4Packet;
@@ -49,7 +51,7 @@
 pub fn frag_overlap(
     packet: &[u8],
     fake_sni: &str,
     fake_ttl_offset: u8,
 ) -> DesyncResult {
     let ip = match parse_ip_header(packet) {
@@ -52,7 +54,7 @@
         None => return DesyncResult::passthrough(),
     };

-    let fake_payload = build_fake_ch(fake_sni);
+    let fake_payload = ch_gen::build_client_hello_default(fake_sni);

     // Фрагмент 1: fake CH, offset=0, MF=1, TTL-1
     let frag1_ttl = ip.ttl.saturating_sub(fake_ttl_offset);
@@ -324,389 +326,3 @@
     DesyncResult::inject_many(inject)
 }

